# NotifyByWebApp configuration — copy to .env / set as Vercel environment variables.
# NEVER commit real values (this repo is public).

# Web Push VAPID key pair — generate locally with:
#   python scripts/generate_vapid_keys.py
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# Contact for push services (mailto: or https: URL), sent in the VAPID JWT "sub" claim
VAPID_SUBJECT=mailto:you@example.com

# Upstash Redis REST API (Vercel Marketplace "Upstash for Redis" integration sets
# KV_REST_API_URL / KV_REST_API_TOKEN automatically; UPSTASH_* names also accepted).
# Without these, an in-memory store is used (fine for local dev/tests only:
# data is lost whenever the serverless instance is recycled).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secret that gates GET /api/status (operational diagnostics). Generate any
# long random string; without it the status endpoint is disabled (404).
# Provide it as an "Authorization: Bearer <secret>" header or ?key=<secret>.
NBW_STATUS_SECRET=

# Optional tuning (defaults shown)
#NBW_RATE_PER_MIN=120
#NBW_MAX_SUBS_PER_CHANNEL=200
#NBW_MAX_MESSAGES=50
#NBW_CHANNEL_TTL_DAYS=400
